generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id       Int      @id @default(autoincrement())
  name     String?
  email    String   @unique
  bookings Booking[]
}

model Service {
  id        Int       @id @default(autoincrement())
  name      String
  slug      String    @unique
  providers Provider[]
}

model Provider {
  id        Int      @id @default(autoincrement())
  name      String
  rating    Float?
  service   Service  @relation(fields: [serviceId], references: [id])
  serviceId Int
  bookings  Booking[]
}

model Booking {
  id         Int      @id @default(autoincrement())
  user       User?    @relation(fields: [userId], references: [id])
  userId     Int?
  provider   Provider @relation(fields: [providerId], references: [id])
  providerId Int
  scheduledAt DateTime
  status     String   @default("pending")
}
